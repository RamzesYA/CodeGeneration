@startuml

' ==============================
' 📦 Простая система библиотеки
' ==============================

class Book {
  {field} - isbn: String
  {field} - title: String
  {field} - author: String
  {field} - isAvailable: boolean
  {method} + borrow(): void
  {method} + returnBook(): void
}

class Library {
  {field} - name: String
  {field} - address: String
  {method} + addBook(book: Book): void
  {method} + findBook(title: String): Book
  {method} + listAvailableBooks(): List<Book>
}

class Reader {
  {field} - readerId: int
  {field} - name: String
  {field} - email: String
  {method} + borrowBook(book: Book): boolean
  {method} + returnBook(book: Book): void
}

' ==============================
' 🧭 Отношения между классами
' ==============================

' Агрегация: библиотека содержит книги, но книги могут существовать независимо
Library o-- "0..*" Book

' Ассоциация: читатель взаимодействует с книгами
Reader "1" -- "0..*" Book

@enduml